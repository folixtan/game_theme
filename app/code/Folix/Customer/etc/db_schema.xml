<?xml version="1.0"?>
<!--
/**
 * Folix Customer Module - Declarative Schema
 *
 * 用户每日统计表定义
 * 
 * 设计原则：
 * - 按天统计：每天每个客户一条记录
 * - 防重复：同一天多次执行只会覆盖
 * - 易追溯：可查看历史趋势
 */
-->
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="folix_customer_daily_stats" resource="default" engine="innodb" comment="Folix Customer Daily Statistics">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Primary Key"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false" identity="false" comment="Customer ID"/>
        <column xsi:type="date" name="stat_date" nullable="false" comment="Statistics Date (YYYY-MM-DD)"/>
        <column xsi:type="int" name="orders_count" unsigned="true" nullable="false" identity="false" default="0" comment="Orders Count for This Day"/>
        <column xsi:type="decimal" name="orders_amount" scale="4" precision="12" unsigned="false" nullable="false" default="0.0000" comment="Orders Amount for This Day"/>
        <column xsi:type="int" name="active_keys_count" unsigned="true" nullable="false" identity="false" default="0" comment="Active Keys Count for This Day"/>
        <column xsi:type="int" name="direct_charges_count" unsigned="true" nullable="false" identity="false" default="0" comment="Direct Charges Count for This Day"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        
        <!-- 唯一索引：防止同一天重复统计 -->
        <constraint xsi:type="unique" referenceId="FOLIX_CUSTOMER_DAILY_STATS_CUSTOMER_DATE_UNIQUE">
            <column name="customer_id"/>
            <column name="stat_date"/>
        </constraint>
        
        <!-- 外键约束 -->
        <constraint xsi:type="foreign" referenceId="FOLIX_CUST_DAILY_STATS_CUST_ID_CUST_ENTITY_ENT_ID" table="folix_customer_daily_stats" column="customer_id" referenceTable="customer_entity" referenceColumn="entity_id" onDelete="CASCADE"/>
        
        <!-- 索引优化查询 -->
        <index referenceId="FOLIX_CUSTOMER_DAILY_STATS_CUSTOMER_ID" indexType="btree">
            <column name="customer_id"/>
        </index>
        <index referenceId="FOLIX_CUSTOMER_DAILY_STATS_STAT_DATE" indexType="btree">
            <column name="stat_date"/>
        </index>
    </table>
</schema>
