<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="customer_account"/>
    <body>
        <referenceContainer name="content">
            <block class="Folix\Customer\Block\Account\GameKeys" 
                   name="folix.customer.gamekeys.list" 
                   template="Folix_Customer::account/game_keys.phtml" 
                   cacheable="false"/>
        </referenceContainer>
        <referenceBlock name="root">
            <action method="setHeaderTitle">
                <argument translate="true" name="title" xsi:type="string">My Game Keys</argument>
            </action>
        </referenceBlock>
    </body>
</page>
