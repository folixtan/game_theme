<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <route url="/V1/folix-simple-checkout/validate-email" method="POST">
        <service class="Folix\SimpleCheckout\Api\ValidateEmailInterface" method="isEmailAvailable"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

</routes>