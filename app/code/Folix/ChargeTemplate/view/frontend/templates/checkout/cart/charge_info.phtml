<?php
/**
 * 购物车页面显示充值信息
 * 
 * @var $block \Folix\ChargeTemplate\Block\Checkout\CartInfo
 */
?>

<?php foreach ($block->getQuoteItems() as $item): ?>
    <?php if ($block->hasChargeData($item)): ?>
        <div class="cart-item-charge-info" data-item-id="<?= $block->escapeHtmlAttr($item->getId()) ?>">
            <div class="charge-info-label"><?= $block->escapeHtml(__('Top-up Information')) ?>:</div>
            <div class="charge-info-content">
                <?= $block->formatChargeInfo($block->getItemChargeData($item)) ?>
            </div>
        </div>
    <?php endif; ?>
<?php endforeach; ?>
