<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!-- API客户端首选项 -->
    <preference for="FolixCode\BaseSyncService\Api\ExternalApiClientInterface" 
                type="FolixCode\BaseSyncService\Model\ApiClient"/>

    <!-- 加密策略接口首选项 -->
    <preference for="FolixCode\BaseSyncService\Api\EncryptionStrategyInterface" 
                type="FolixCode\BaseSyncService\Model\Encryption\Aes256CbcStrategy"/>

    <!-- VendorConfig接口首选项（默认实现） -->
    <preference for="FolixCode\BaseSyncService\Api\VendorConfigInterface" 
                type="FolixCode\BaseSyncService\Model\DefaultVendorConfig"/>
</config>
