<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Communication/etc/communication.xsd">
    <!-- 产品导入主题 -->
    <topic name="folixcode.product.import" request="FolixCode\ProductSync\Api\Message\ProductImportMessageInterface">
        <handler name="folixcode.product.import" type="FolixCode\ProductSync\Model\MessageQueue\Consumer\ProductImportConsumer" method="process" />
    </topic>

    <!-- 分类导入主题 -->
    <topic name="folixcode.category.import" request="FolixCode\ProductSync\Api\Message\CategoryImportMessageInterface">
        <handler name="folixcode.category.import" type="FolixCode\ProductSync\Model\MessageQueue\Consumer\CategoryImportConsumer" method="process" />
    </topic>

    <!-- 产品详情导入主题 -->
    <topic name="folixcode.product.detail" request="FolixCode\ProductSync\Api\Message\ProductDetailMessageInterface">
        <handler name="folixcode.product.detail" type="FolixCode\ProductSync\Model\MessageQueue\Consumer\ProductDetailConsumer" method="process" />
    </topic>
</config>