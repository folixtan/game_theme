<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- 引入卡密信息样式 -->
        <css src="FolixCode_ThirdPartyOrder::css/card-info.css"/>
    </head>
    <body>
        <!-- 在 sales.order.view Block 中添加卡密信息子块 -->
        <referenceBlock name="sales.order.view">
            <block class="FolixCode\ThirdPartyOrder\Block\Customer\CardInfo" 
                   name="folix.thirdparty.cardinfo" 
                   template="FolixCode_ThirdPartyOrder::card_info.phtml"
                   after="order_items"/>
        </referenceBlock>
    </body>
</page>
