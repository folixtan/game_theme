<?php
/**
 * Card Info Template - 显示订单中所有卡密信息
 *
 * @var $block \FolixCode\ThirdPartyOrder\Block\Customer\CardInfo
 */

if (!$block->shouldDisplay()) {
    return;
}

$thirdPartyOrders = $block->getThirdPartyOrders();
?>

<div class="folix-card-info-section">
    <div class="card-info-title">
        <strong><?= $block->escapeHtml(__('Card Information')) ?></strong>
    </div>

    <?php foreach ($thirdPartyOrders as $index => $thirdPartyOrder): ?>
        <!-- 卡密订单信息 -->
        <div class="folix-card-info" data-entity-id="<?= $block->escapeHtmlAttr((string)$thirdPartyOrder->getId()) ?>">
            <?php if (count($thirdPartyOrders) > 1): ?>
                <div class="card-info-header">
                    <span class="card-icon">🔑</span>
                    <strong><?= $block->escapeHtml(__('Card Details')) ?> #<?= $index + 1 ?></strong>
                </div>
            <?php else: ?>
                <div class="card-info-header">
                    <span class="card-icon">🔑</span>
                    <strong><?= $block->escapeHtml(__('Card Details')) ?></strong>
                </div>
            <?php endif; ?>
            
            <!-- 卡号 -->
            <div class="card-info-row">
                <label><?= $block->escapeHtml(__('Card Number')) ?>:</label>
                <div class="card-value-wrapper">
                    <span class="card-value card-no"><?= $block->escapeHtml($thirdPartyOrder->getCardNo() ?? '') ?></span>
                    <button type="button" class="copy-btn" data-field="card_no" title="<?= $block->escapeHtmlAttr(__('Copy to clipboard')) ?>">
                        <svg class="copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                        </svg>
                        <span class="copy-text"><?= $block->escapeHtml(__('Copy')) ?></span>
                    </button>
                </div>
            </div>
            
            <!-- 密码 (默认隐藏) -->
            <div class="card-info-row">
                <label><?= $block->escapeHtml(__('Password')) ?>:</label>
                <div class="card-value-wrapper">
                    <span class="card-value masked" data-masked="true">••••••••••••</span>
                    <span class="card-value plain" style="display:none;"><?= $block->escapeHtml($thirdPartyOrder->getCardPwd() ?? '') ?></span>
                    <button type="button" class="toggle-btn" data-action="toggle" title="<?= $block->escapeHtmlAttr(__('Show/Hide Password')) ?>">
                        <svg class="eye-icon eye-open" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                        </svg>
                        <svg class="eye-icon eye-closed" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none;">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
                            <line x1="1" y1="1" x2="23" y2="23"></line>
                        </svg>
                        <span class="toggle-text"><?= $block->escapeHtml(__('Show')) ?></span>
                    </button>
                    <button type="button" class="copy-btn copy-pwd-btn" data-field="card_pwd" title="<?= $block->escapeHtmlAttr(__('Copy to clipboard')) ?>" disabled>
                        <svg class="copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                        </svg>
                        <span class="copy-text"><?= $block->escapeHtml(__('Copy')) ?></span>
                    </button>
                </div>
            </div>
            
            <!-- 过期时间 -->
            <div class="card-info-row">
                <label><?= $block->escapeHtml(__('Expires')) ?>:</label>
                <div class="card-value-wrapper">
                    <?php 
                    $deadline = $thirdPartyOrder->getCardDeadline();
                    $isExpired = $block->isExpired($deadline);
                    ?>
                    <span class="card-value deadline-value <?= $isExpired ? 'expired' : '' ?>">
                        <?= $block->escapeHtml($block->formatDeadline($deadline)) ?>
                        <?php if ($isExpired): ?>
                            <span class="expired-badge">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <line x1="12" y1="8" x2="12" y2="12"></line>
                                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                                </svg>
                                <?= $block->escapeHtml(__('EXPIRED')) ?>
                            </span>
                        <?php endif; ?>
                    </span>
                </div>
            </div>
        </div>
    <?php endforeach; ?>
    
    <!-- 复制全部按钮（如果有多个卡密） -->
    <?php if (count($thirdPartyOrders) > 1): ?>
        <div class="copy-all-wrapper">
            <button type="button" class="copy-all-btn" id="copyAllCards">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                <?= $block->escapeHtml(__('Copy All Cards')) ?>
            </button>
        </div>
    <?php endif; ?>
</div>

<script type="text/x-magento-init">
{
    ".folix-card-info-section": {
        "FolixCode_ThirdPartyOrder/js/card-info": {}
    }
}
</script>
