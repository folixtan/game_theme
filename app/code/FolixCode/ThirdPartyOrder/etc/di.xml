<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- API接口绑定 -->
    <preference for="FolixCode\ThirdPartyOrder\Api\ThirdPartyOrderDbRepositoryInterface" 
                type="FolixCode\ThirdPartyOrder\Model\ThirdPartyOrderDbRepository" />
                
    <preference for="FolixCode\ThirdPartyOrder\Api\Data\ThirdPartyOrderDbInterface" 
                type="FolixCode\ThirdPartyOrder\Model\ThirdPartyOrderDb" />

    <!-- API Response Transformer 接口绑定 -->
    <preference for="FolixCode\ThirdPartyOrder\Api\Data\ApiResponseTransformerInterface" 
                type="FolixCode\ThirdPartyOrder\Model\Transformer\DefaultApiResponseTransformer" />

    <!-- API客户端首选项 -->
    <preference for="FolixCode\BaseSyncService\Api\ExternalApiClientInterface" 
                type="FolixCode\BaseSyncService\Model\ApiClient"/>

    <!-- 加密策略接口首选项 -->
    <preference for="FolixCode\BaseSyncService\Api\EncryptionStrategyInterface" 
                type="FolixCode\BaseSyncService\Model\Encryption\Aes256CbcStrategy"/>

    <!-- ThirdPartyOrder专用的ApiClient实例（可切换为Mock） -->
    <!-- 
        开发环境使用 Mock: type="FolixCode\ThirdPartyOrder\Model\MockApiClient"
        生产环境使用真实: type="FolixCode\BaseSyncService\Model\ApiClient"
    -->
    <virtualType name="ThirdPartyOrderApiClient" type="FolixCode\ThirdPartyOrder\Model\ApiClient">
        <arguments>
            <argument name="vendorConfig" xsi:type="object">FolixCode\BaseSyncService\Model\DefaultVendorConfig</argument>
            <argument name="encryptionStrategy" xsi:type="object">FolixCode\BaseSyncService\Api\EncryptionStrategyInterface</argument>
            <argument name="logger" xsi:type="object">FolixCodeThirdPartyOrderLogger</argument>
        </arguments>
    </virtualType>

    <!-- OrderSyncService配置 -->
    <type name="FolixCode\ThirdPartyOrder\Model\OrderSyncService">
        <arguments>
            <argument name="apiClient" xsi:type="object">ThirdPartyOrderApiClient</argument>
        </arguments>
    </type>

    <!-- Logger -->
    <virtualType name="FolixCodeThirdPartyOrderLogger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">thirdpartyorder</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">FolixCodeThirdPartyOrderLogHandler</item>
            </argument>
        </arguments>
    </virtualType>
    
    <virtualType name="FolixCodeThirdPartyOrderLogHandler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
            <argument name="fileName" xsi:type="string">/var/log/thirdpartyorder.log</argument>
        </arguments>
    </virtualType>

    <!-- Console Command -->
    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="process_third_party_orders_command" xsi:type="object">FolixCode\ThirdPartyOrder\Console\Command\ProcessThirdPartyOrdersCommand</item>
            </argument>
        </arguments>
    </type>

</config>