<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    
    <!-- Logger Handler -->
    <virtualType name="FolixCode\ThirdPartyOrder\Logger\Handler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/folixcode_thirdpartyorder.log</argument>
        </arguments>
    </virtualType>
    
    <!-- Logger -->
    <virtualType name="FolixCode\ThirdPartyOrder\Logger\Logger" type="Monolog\Logger">
        <arguments>
            <argument name="name" xsi:type="string">folixcode_thirdpartyorder</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">FolixCode\ThirdPartyOrder\Logger\Handler</item>
            </argument>
        </arguments>
    </virtualType>

</config>
