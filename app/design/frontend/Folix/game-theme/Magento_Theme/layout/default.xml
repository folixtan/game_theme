<?xml version="1.0"?>
<!--
/**
 * Folix Game Theme - Default Layout
 *
 * 基于 Magento 原生结构改造
 *
 * PC 端：
 * - Top Bar (header.panel)：深蓝渐变背景，高度40px
 *   ├── 左侧：新闻、奖励、支持
 *   └── 右侧：APP、语言、登录/用户信息
 * - Main Bar (header.content)：白色背景，高度70px，底部橙色边框3px
 *   ├── Logo
 *   ├── 导航菜单
 *   ├── 搜索框
 *   └── 购物车
 *
 * 移动端：
 * - Header (mobile-header)：高度60px，底部橙色边框3px
 *   ├── 左侧：汉堡菜单 ☰
 *   └── 右侧：购物车 🛒
 * - 侧边栏（navigation.sections）：
 *   ├── 顶部：品牌 + 关闭按钮
 *   ├── MENU 标签
 *   ├── 菜单项
 *   ├── Account 标签（登录/用户信息）
 *   └── 搜索框
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- =================================================================
             HEADER PANEL - Top Bar
             深蓝渐变背景，高度40px
             ================================================================= -->

        <!-- 移除不需要的原生元素 -->
        <referenceBlock name="skip_to_content" remove="true" />
        <referenceBlock name="catalog.compare.link" remove="true" />
        <referenceBlock name="currency" remove="true" />
        <referenceBlock name="report.bugs" remove="true" />
        <referenceBlock name="store_switcher" remove="true" />

        <!-- 隐藏原生的 header.links（我们用自定义的） -->
        <referenceBlock name="header.links" remove="true" />

        <!-- =================================================================
             TOP BAR 内容
             ================================================================= -->

        <!-- 左侧链接 -->
        <block class="Magento\Framework\View\Element\Template" name="folix.top.links" template="Magento_Theme::html/header/links-top-left.phtml" />

        <!-- 右侧 APP 链接 -->
        <block class="Magento\Framework\View\Element\Template" name="folix.app.link" template="Magento_Theme::html/header/app-link.phtml" />

        <!-- 语言切换（原生，移到 header.panel） -->
        <move element="store_language" destination="header.panel" after="folix.app.link" />

        <!-- 登录/用户信息 -->
        <block class="Magento\Framework\View\Element\Template" name="folix.top.auth" template="Magento_Theme::html/header/top-bar-auth.phtml" />

        <!-- =================================================================
             MAIN BAR 内容
             ================================================================= -->

        <!-- Logo（原生） -->
        <move element="logo" destination="header.content" before="-" />

        <!-- 导航菜单（原生） -->
        <move element="catalog.topnav" destination="header.content" after="logo" />

        <!-- 搜索框（原生） -->
        <move element="top.search" destination="header.content" after="catalog.topnav" />

        <!-- 购物车（原生） -->
        <move element="minicart" destination="header.content" after="top.search" />

        <!-- =================================================================
             MOBILE NAVIGATION SECTIONS
             侧边栏（使用原生 navigation.sections）
             ================================================================= -->

        <referenceContainer name="after.body.start">
            <block class="Magento\Framework\View\Element\Template"
                   name="navigation.sections"
                   template="Magento_Theme::html/sections.phtml"
                   before="-">
                <arguments>
                    <argument name="group_name" xsi:type="string">navigation-sections</argument>
                    <argument name="group_css" xsi:type="string">nav-sections mobile-sidebar</argument>
                </arguments>

                <!-- Menu 区块 -->
                <block class="Magento\Framework\View\Element\Template"
                       name="store.menu"
                       group="navigation-sections"
                       template="Magento_Theme::html/container.phtml">
                    <arguments>
                        <argument name="title" translate="true" xsi:type="string">Menu</argument>
                    </arguments>
                    <!-- Menu 内容：catalog.topnav -->
                    <block class="Magento\Theme\Block\Html\Topmenu"
                           name="catalog.topnav"
                           template="Magento_Theme::html/topmenu.phtml"
                           ttl="3600"
                           before="-"/>
                </block>

                <!-- Account 区块 -->
                <block class="Magento\Framework\View\Element\Template"
                       name="store.links"
                       group="navigation-sections"
                       template="Magento_Theme::html/container.phtml">
                    <arguments>
                        <argument name="title" translate="true" xsi:type="string">Account</argument>
                    </arguments>
                    <!-- Account 内容：header.links -->
                    <block class="Magento\Customer\Block\Account\Link" name="my-account-link"/>
                    <block class="Magento\Customer\Block\Account\RegisterLink" name="register-link"/>
                    <block class="Magento\Customer\Block\Account\AuthorizationLink" name="authorization-link"/>
                </block>
            </block>

            <!-- 移动端导航遮罩层 -->
            <block class="Magento\Framework\View\Element\Template" name="mobile.nav.overlay" template="Magento_Theme::html/nav-overlay.phtml" />
        </referenceContainer>

        <!-- =================================================================
             BODY CLASS
             ================================================================= -->

        <attribute name="body" value="folix-theme" />

    </body>
</page>
