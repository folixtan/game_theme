<?xml version="1.0"?>
<!--
/**
 * Folix Game Theme - Default Layout
 *
 * 基于所有模块合并后的完整结构：
 * - module-theme: 定义基本结构
 * - module-customer: 定义登录/注册链接
 * - module-catalog-search: 定义搜索框
 * - mageplaza-social-login: 定义社交登录
 *
 * 各司其职，只做组织、删除、移动、定制
 *
 * 头部结构（严格按原型）：
 *
 * Top Bar (header.panel) - 深蓝渐变背景，高度40px
 * ├── 左侧：新闻、奖励、支持链接（自定义 Block）
 * ├── 右侧：APP 下载（自定义 Block）+ 语言切换（移动）
 * └── 原生：top.links（登录/注册/用户信息，由 Customer 模块添加）
 *
 * Main Bar (header-wrapper) - 白色背景，高度70px，底部橙色边框3px
 * ├── Logo（原生）
 * ├── 导航菜单（catalog.topnav，PC 端显示）
 * ├── 搜索框（top.search，从 page.top 移来）
 * └── 购物车（minicart，从 page.bottom 移来）
 *
 * 移动端导航（page.top）
 * ├── navigation.sections（保留，侧边栏样式）
 * └── 用 CSS 控制汉堡菜单和遮罩层
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- =================================================================
             删除不需要的原生元素
             ================================================================= -->

        <referenceBlock name="skip_to_content" remove="true" />
        <referenceBlock name="currency" remove="true" />
        <referenceBlock name="report.bugs" remove="true" />

        <!-- =================================================================
             TOP BAR - header.panel Container
             原生结构：
             - skip_to_content (已删除)
             - store_language
             - store_switcher (从 footer 移来)
             - top.links (Customer 模块添加子 block)
             ================================================================= -->

        <referenceContainer name="header.panel">
            <!-- 左侧：新闻、奖励、支持链接 -->
            <block class="Magento\Framework\View\Element\Template"
                   name="folix.top.links"
                   template="Magento_Theme::html/header/links-top-left.phtml"
                   before="store_language" />

            <!-- 右侧：APP 下载链接 -->
            <block class="Magento\Framework\View\Element\Template"
                   name="folix.app.link"
                   template="Magento_Theme::html/header/app-link.phtml"
                   after="folix.top.links" />

            <!-- store_language 原生存在，保持不变 -->
            <!-- store_switcher 从 footer 移到 header.panel，在 store_language 之后 -->
            <!-- top.links 原生存在，由 Customer 模块添加子 block，保持不变 -->
        </referenceContainer>

        <!-- =================================================================
             移动元素（必须在 body 直接子级，不能放在 referenceContainer 内部）
             ================================================================= -->

        <!-- 移动 store_switcher 到 header.panel，在 store_language 之后，top.links 之前 -->
        <move element="store_switcher" destination="header.panel" after="store_language" />

        <!-- 移动 catalog.topnav 到 header-wrapper，在 logo 之后 -->
        <move element="catalog.topnav" destination="header-wrapper" after="logo" />

        <!-- 移动 top.search 到 header-wrapper，在 catalog.topnav 之后 -->
        <move element="top.search" destination="header-wrapper" after="catalog.topnav" />

        <!-- 移动 minicart 到 header-wrapper，在 top.search 之后 -->
        <move element="minicart" destination="header-wrapper" after="top.search" />

        <!-- =================================================================
             MAIN BAR - header-wrapper Container
             原生结构：
             - logo
             - catalog.topnav (从 page.top 移来)
             - top.search (从 page.top 移来)
             - minicart (从 page.bottom 移来)
             ================================================================= -->

        <referenceContainer name="header-wrapper">
            <!-- Logo 原生存在，保持不变 -->

            <!-- PC 端导航菜单：使用 catalog.topnav（原生），添加自定义 CSS class -->
            <!-- catalog.topnav 从 page.top 移来，在 logo 之后 -->
            <!-- top.search 从 page.top 移来，在 catalog.topnav 之后 -->
            <!-- minicart 从 page.bottom 移来，在 top.search 之后 -->
        </referenceContainer>

        <!-- 为 catalog.topnav 添加自定义 CSS class -->
        <referenceBlock name="catalog.topnav">
            <arguments>
                <argument name="css_class" xsi:type="string">desktop-nav</argument>
            </arguments>
        </referenceBlock>

        <!-- =================================================================
             移动端导航 - page.top Container
             保留 navigation.sections，侧边栏样式
             ================================================================= -->

        <referenceContainer name="page.top">
            <!-- navigation.sections 原生存在，保持不变 -->
            <!-- 包含：store.menu、store.links、store.settings -->

            <!-- 移动端遮罩层（自定义） -->
            <block class="Magento\Framework\View\Element\Template"
                   name="mobile.nav.overlay"
                   template="Magento_Theme::html/nav-overlay.phtml"
                   after="navigation.sections" />

            <!-- 移动端汉堡菜单按钮（自定义） -->
            <block class="Magento\Framework\View\Element\Template"
                   name="mobile.nav.toggle"
                   template="Magento_Theme::html/nav-toggle.phtml"
                   after="mobile.nav.overlay" />
        </referenceContainer>

        <!-- =================================================================
             Body Class
             ================================================================= -->

        <attribute name="body" value="folix-theme" />

    </body>
</page>
