// /**
//  * Folix Game Theme - Navigation Styles
//  *
//  * 模块：Magento_Theme
//  * 位置：Magento_Theme/web/css/source/Magento_Theme/_navigation.less
//  *
//  * 修复说明：
//  * - 保留原生移动端导航机制
//  * - 只修改样式（颜色、背景等）
//  * - 不改变布局逻辑
//  */

//
//  Common (All devices)
//  _____________________________________________

& when (@media-common = true) {

    

    // ============================================
    //  Navigation - 通用导航样式
    //  ============================================

    .navigation {
        ul {
            list-style: none;
            margin: 0;
            padding: 0;

            li {
                margin: 0;
                padding: 0;

                a {
                    text-decoration: none;
                    display: block;

                    &:hover {
                        text-decoration: none;
                    }
                }
            }
        }

        // 子菜单
        .submenu {
            list-style: none;
            margin: 0;
            padding: 0;
        }
    }

    // ============================================
    //  Breadcrumbs - 面包屑
    //  ============================================

    .breadcrumbs {
        a {
            &:hover {
                color: @folix-secondary;
            }
        }

        strong {
            color: @folix-text-primary;
        }
    }
}

//
//  Desktop (≥ 768px) - PC 端水平导航
//  _____________________________________________

.media-width(@extremum, @break) when (@extremum = 'min') and (@break = @screen__m) {

    // ============================================
    //  PC 端导航栏
    //  ============================================

    .sections.nav-sections {
        display: block;
        background: transparent;
        border-bottom: 1px solid @folix-nav-bottom-border;

        .section-items {
            display: flex;
            height: 100%;
        }

        // 隐藏移动端标题
        .section-item-title {
            display: none;
        }

        // 显示导航内容
        .section-item-content {
            display: block;
            height: 100%;

            .navigation {
                ul {
                    display: flex;
                    gap: 8px;

                    > li {
                        position: relative;

                        > a {
                            padding: 14px 16px;
                            color: @folix-text-primary;
                            font-weight: @font-weight__semibold;
                            border-radius: @folix-radius-sm;
                            transition: all 0.3s ease;

                            span {
                                color: @folix-text-primary;
                            }

                            &:hover {
                                color: @folix-secondary;
                                background: @folix-bg-selected;

                                span {
                                    color: @folix-secondary;
                                }
                            }
                        }

                        &.active > a {
                            color: @folix-secondary;
                            background: @folix-bg-selected;

                            span {
                                color: @folix-secondary;
                            }
                        }

                        // 下拉子菜单
                        .submenu {
                            position: absolute;
                            top: 100%;
                            left: 0;
                            background: @folix-bg-panel;
                            border: 1px solid @folix-border;
                            min-width: 220px;
                            border-radius: @folix-radius-md;
                            box-shadow: @folix-shadow-lg;
                            opacity: 0;
                            visibility: hidden;
                            z-index: 100;

                            li {
                                border-bottom: 1px solid @folix-border-light;

                                &:last-child {
                                    border-bottom: none;
                                }

                                a {
                                    padding: 12px 16px;
                                    color: @folix-text-primary;
                                    font-size: 14px;
                                    transition: all 0.3s ease;

                                    &:hover {
                                        color: @folix-secondary;
                                        background: @folix-bg-hover;
                                    }
                                }

                                // 三级子菜单
                                .submenu {
                                    position: absolute;
                                    top: 0;
                                    left: 100%;
                                    opacity: 0;
                                    visibility: hidden;

                                    li {
                                        a {
                                            &:hover {
                                                color: @folix-secondary;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        &:hover > .submenu {
                            opacity: 1;
                            visibility: visible;
                        }

                        &:hover > .submenu .submenu {
                            display: none;
                        }

                        // 三级子菜单悬停显示
                        li:hover > .submenu {
                            display: block;
                            opacity: 1;
                            visibility: visible;
                        }
                    }
                }
            }
        }
    }
}

//
//  Mobile (< 768px) - 移动端导航
//  _____________________________________________

.media-width(@extremum, @break) when (@extremum = 'max') and (@break = @screen__m) {

    // 显示汉堡菜单按钮
    .nav-toggle {
        display: block;
    }

    // ============================================
    //  覆盖父主题的导航颜色
    //  ============================================

    .navigation {
        background: @folix-bg-dark;

        a {
            color: @folix-text-primary;
            text-decoration: none;

            &:hover {
                color: @folix-secondary;
                text-decoration: none;
            }
        }
    }

    // ============================================
    //  移动端导航样式增强
    //  只修改颜色和背景，不改变布局
    //  ============================================

    // 导航区域背景
    .nav-sections {
        background: @folix-bg-dark;
    }

    // 标签样式
    .nav-sections-item-title {
        background: @folix-bg-dark-alt;
        border-color: @folix-border;

        &.active {
            background: @folix-bg-dark;
        }

        .nav-sections-item-switch {
            color: @folix-text-primary;
            font-weight: @font-weight__semibold;
            text-transform: uppercase;
            letter-spacing: 1px;

            &:hover {
                color: @folix-secondary;
                text-decoration: none;
            }
        }
    }

    // 导航项样式
    .navigation .level0 {
        border-top-color: @folix-border-light;

        > .level-top {
            color: @folix-text-primary;
            font-weight: @font-weight__semibold;

            &:hover {
                color: @folix-secondary;
            }
        }

        &.active > a,
        &.has-active > a {
            border-color: @folix-secondary;
            color: @folix-secondary;
        }
    }

    // 子菜单样式
    .navigation .submenu:not(:first-child) {
        background: @folix-bg-page;

        > li > a {
            color: @folix-text-secondary;

            &:hover {
                color: @folix-secondary;
            }
        }

        ul > li a {
            color: @folix-text-tertiary;

            &:hover {
                color: @folix-secondary;
            }
        }
    }

    // 遮罩层样式（原生使用.nav-toggle:after）
    .nav-open .nav-toggle:after {
        background: rgba(0, 0, 0, 0.7);
    }
}
