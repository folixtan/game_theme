<?xml version="1.0"?>
<!--
/**
 * Folix Game Theme - Customer Module Layout
 *
 * 电竞风定制 - Customer 模块布局
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>  
        <referenceBlock name="top.links">
            <arguments>
               <argument name="css_class" xsi:type="string">user-dropdown-menu</argument>
            </arguments>
        </referenceBlock>
        
         <referenceBlock name="header.links">
            <block class="Magento\Framework\View\Element\Template" name="customer-nocache" template="Magento_Customer::account/customer-nocache.phtml" before="-" cacheable="false"/>
        </referenceBlock>
        <move element="customer" destination="customer-nocache" after="-" />
         <move element="header.links" destination="folix.top.right" after="-" />  
    </body>
</page>
